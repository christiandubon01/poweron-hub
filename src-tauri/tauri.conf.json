{
  "$schema": "../node_modules/@tauri-apps/cli/schema.json",
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "devPath": "http://localhost:5173",
    "distDir": "../dist"
  },
  "package": {
    "productName": "PowerOn Hub",
    "version": "2.0.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": {
        "all": false,
        "open": true
      },
      "dialog": {
        "all": true,
        "ask": true,
        "confirm": true,
        "message": true,
        "open": true,
        "save": true
      },
      "fs": {
        "all": false,
        "readFile": true,
        "writeFile": true,
        "readDir": true,
        "createDir": true,
        "scope": ["$APPDATA/**", "$DOWNLOAD/**", "$DOCUMENT/**"]
      },
      "notification": {
        "all": true
      },
      "path": {
        "all": true
      },
      "window": {
        "all": false,
        "close": true,
        "hide": true,
        "show": true,
        "maximize": true,
        "minimize": true,
        "unmaximize": true,
        "unminimize": true,
        "startDragging": true,
        "setTitle": true,
        "setSize": true,
        "setMinSize": true,
        "center": true,
        "setFocus": true,
        "setFullscreen": true
      }
    },
    "bundle": {
      "active": true,
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ],
      "identifier": "com.poweronsolutions.hub",
      "targets": "all",
      "category": "Business",
      "shortDescription": "AI-powered operations hub for electrical contractors",
      "longDescription": "PowerOn Hub is an AI-powered operations platform designed for electrical contracting businesses. Features 11 specialized AI agents for estimating, scheduling, invoicing, marketing, and more."
    },
    "security": {
      "csp": "default-src 'self'; connect-src 'self' https://*.supabase.co https://*.upstash.io https://api.anthropic.com https://api.openai.com https://api.elevenlabs.io https://api.stripe.com; img-src 'self' data: https:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; font-src 'self' data:"
    },
    "windows": [
      {
        "title": "PowerOn Hub",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": true,
        "transparent": false
      }
    ]
  }
}
