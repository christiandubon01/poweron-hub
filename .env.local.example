# ══════════════════════════════════════════════════════════════════════════════
# PowerOn Hub — Environment Variables
# Copy this file to .env.local and fill in your actual values.
# NEVER commit .env.local to git.
# ══════════════════════════════════════════════════════════════════════════════

# ── Supabase ──────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service role key — NEVER expose in frontend; only used in Edge Functions
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Project ref — for Management API calls in Edge Functions
SUPABASE_PROJECT_REF=your-project-ref
SUPABASE_URL=https://your-project-ref.supabase.co

# ── Upstash Redis ─────────────────────────────────────────────────────────────
# Found in: upstash.com → Console → Database → Details
# NOTE: Upstash uses HTTPS REST API, not a raw Redis URL
VITE_UPSTASH_REDIS_URL=https://your-database.upstash.io
VITE_UPSTASH_REDIS_TOKEN=AXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── OpenAI (vector embeddings) ────────────────────────────────────────────────
# Used by: src/lib/memory/embeddings.ts (text-embedding-3-small)
VITE_OPENAI_API_KEY=sk-proj-...

# ── Anthropic (agent reasoning — Phase 02) ────────────────────────────────────
# VITE_ prefix required so Vite exposes it to the frontend
VITE_ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Cloudflare R2 (nightly backups) ──────────────────────────────────────────
# Found in: Cloudflare Dashboard → R2 → API Tokens
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_ACCESS_KEY=your-r2-access-key-id
R2_SECRET_KEY=your-r2-secret-access-key
R2_BUCKET=poweron-backups

# ── Stripe (billing — Phase 08) ───────────────────────────────────────────────
# Set up now so the schema columns have values when needed
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ── OneSignal (push notifications — Phase 02) ─────────────────────────────────
VITE_ONESIGNAL_APP_ID=your-onesignal-app-id
ONESIGNAL_API_KEY=your-onesignal-api-key

# ── Google APIs (Calendar sync — Phase 05) ────────────────────────────────────
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...
VITE_GOOGLE_CALENDAR_API_KEY=AIzaSy...

# ── ElevenLabs (voice — Phase 06) ────────────────────────────────────────────
ELEVENLABS_API_KEY=your-elevenlabs-api-key

# ── QuickBooks Online (API sync — V3) ───────────────────────────────────────
# OAuth 2.0 flow: https://oauth.platform.intuit.com/op/v1/
# Invoices endpoint: https://quickbooks.api.intuit.com/v3/company/{realmId}/query
VITE_QUICKBOOKS_CLIENT_ID=your-quickbooks-client-id
VITE_QUICKBOOKS_CLIENT_SECRET=your-quickbooks-client-secret

# ── App metadata ──────────────────────────────────────────────────────────────
VITE_APP_VERSION=0.1.0
VITE_APP_ENV=development
